<launch>
    <!-- AI Lane Detection (Slower startup) -->
    <node pkg="intersection_handling" type="detect_lane.py" name="detect_lane" output="screen" />

    <!-- Intersection & Control Logic -->
    <node pkg="intersection_handling" type="detect_intersection.py" name="detect_intersection" />
    <node pkg="intersection_handling" type="detect_signs.py" name="detect_signs" />
    <node pkg="intersection_handling" type="switch_control.py" name="switch_control" output="screen"/>
    
    <!-- Hardware Control -->
    <!--<node pkg="intersection_handling" type="control_wheels.py" name="control_wheels" output="screen" /> -->

    <!-- Dashboard/UI -->
    <node pkg="intersection_handling" type="dashboard.py" name="dashboard" />
</launch>